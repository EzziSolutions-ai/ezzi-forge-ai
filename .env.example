# Copy this file to .env for local dev, and set the same values in
# Vercel → Project → Settings → Environment Variables for production.
# DO NOT commit .env — it is gitignored.
#
# ── Lead email (required) ──────────────────────────────────────────
# Every website form (contact, pricing, prototype quote, newsletter) is
# emailed to sales@ezzisolutions.ai by the /api/lead serverless function
# via Resend. Get an API key at https://resend.com and verify the
# ezzisolutions.ai domain there so the "from" address is accepted.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides (defaults shown):
#   LEAD_TO   = sales@ezzisolutions.ai
#   LEAD_FROM = Ezzi Solutions Website <leads@updates.ezzisolutions.ai>
# LEAD_FROM must be on a Resend-verified domain (updates.ezzisolutions.ai).
# LEAD_TO=sales@ezzisolutions.ai
# LEAD_FROM=Ezzi Solutions Website <leads@updates.ezzisolutions.ai>
# CONFIRM_FROM = sender of the auto-confirmation the visitor receives
#   (also must be a verified-domain address; replies route to LEAD_TO).
# CONFIRM_FROM=Ezzi Solutions AI <sales@updates.ezzisolutions.ai>
# CONFIRM_REPLY_TO = Reply-To on the visitor confirmation (a real inbox that
#   receives mail). The internal lead notification always replies to the
#   prospect's own email, so it has no override.
# CONFIRM_REPLY_TO=sales@ezzisolutions.ai

# ── Slack (optional) ───────────────────────────────────────────────
# If set, /api/lead also posts a short ping to this Slack channel.
# Get yours at https://api.slack.com/apps → Incoming Webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_URL
